# Base URL dofusin-page utilise pour appeler les routes JSON /admin/api/*
# de dofusin-api côté serveur (jamais depuis le navigateur) — appel
# interne serveur-à-serveur sur le même serveur, donc localhost et pas
# api.dofusin.fr (qui, lui, sert le trafic public via Caddy).
DOFUSIN_API_URL=http://localhost:3026

# Doivent avoir EXACTEMENT la même valeur que ADMIN_USERNAME/ADMIN_PASSWORD
# dans dofusin-api/.env — les deux services vérifient indépendamment (voir
# proxy.ts ici, requireAdminAuth côté dofusin-api).
ADMIN_USERNAME=
ADMIN_PASSWORD=

# URL publique (visible du navigateur, donc NEXT_PUBLIC_ — figée au build,
# pas relue à la requête) de la route de téléchargement servie par
# dofusin-api (voir dofusin-api/src/routes/download.ts) — le sous-domaine
# api.dofusin.fr pointe entièrement vers dofusin-api côté Caddy, donc pas
# besoin de préfixe /api ici. L'installeur lui-même se met à jour côté
# dofusin-api (remplacement du fichier), pas ici — ce lien n'a
# normalement jamais besoin de changer.
NEXT_PUBLIC_DOFUSIN_DOWNLOAD_URL=https://api.dofusin.fr/download

# Optionnels — liens du footer de la landing page (icône GitHub, bouton
# "Buy me a coffee"). Tant qu'ils sont absents, les liens correspondants
# sont simplement masqués plutôt que de pointer vers "#".
NEXT_PUBLIC_GITHUB_URL=
NEXT_PUBLIC_BUY_ME_A_COFFEE_URL=
